# Copy this file to `.env` and fill in values for your local machine / identity.
# Do not commit real secrets if this workspace is shared.

# Workspace identity
WORKSPACE_ID=
WORKSPACE_NAME=

# Git identity used by workflow approvals / audit trail
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=
GITHUB_TOKEN=

# GitHub / repo access
GITHUB_ACCOUNT=
SSH_KEY_PATH=

# Optional local preferences
# Note: base branches are per-repo, declared in workspace.yaml (repos[].base_branch)
SKIP_STAGING=false

# Shared workspace root (contains .claude/CLAUDE.shared.md and skills)
WORKSPACE_ROOT=~/workspace/workflow

# Optional local path overrides
WORKSPACE_LOCAL_PATH=
PROJECT_A_API_LOCAL_PATH=
