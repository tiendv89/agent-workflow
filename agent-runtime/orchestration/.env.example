# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Anthropic API key — get one from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Git identity written into task log entries and claim commits.
# Both agents use the same email (the claim protocol uses SHA not identity).
GIT_AUTHOR_EMAIL=you@example.com

# ── Optional ──────────────────────────────────────────────────────────────────

# Directory containing your SSH private key (id_rsa).
# Defaults to ~/.ssh if not set.
# SSH_KEY_DIR=~/.ssh

# SSH URL of the workflow repo — cloned into the container on first run.
# Set this if WORKFLOW_LOCAL_PATH inside the container is empty.
# WORKFLOW_URL=git@github.com:tiendv89/agent-workflow.git

# Go version override — use if 1.25.0 is not yet available on go.dev/dl.
# GO_VERSION=1.24.2
