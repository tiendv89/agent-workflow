# Lean per-task state file.
#
# Narrative (description, subtasks) lives in docs/features/<feature_id>/tasks.md
# beside this directory. This YAML carries only machine-mutable state so agents
# can update one task without contending on a shared file.
#
# Per-task state is the source of truth for: status, depends_on, branch,
# execution, pr, log. Never duplicate these into tasks.md.

id: T1
title: Example task
repo: project-A-api
status: ready       # todo | ready | in_progress | blocked | in_review | done | cancelled
depends_on: []
blocked_reason: null  # null when not blocked. Values when blocked:
                      #   budget_exceeded           — token budget exhausted
                      #   iteration_cap_exceeded    — max loop iterations reached
                      #   no_progress               — same tool call repeated 3x
                      #   model_escalation_requested — agent needs a more capable model
                      #   skill_missing             — required skill not in workflow repo
                      #   runtime_error             — uncaught exception; see blocked_details
blocked_details: null # Optional: structured context for blocked_reason.
                      # For model_escalation_requested: includes current_model.
                      # For runtime_error: truncated stack trace.
branch: feature/FEATURE-001-T1

execution:
  actor_type: agent   # human | agent | either
  last_updated_by: null
  last_updated_at: null
  suggested_next_step: null  # Written by agent when blocking; human triage hint.

pr:
  url: ""
  status: not_created

log:
  - action: created
    by: tech_lead
    at: 2026-01-01T00:00:00Z
    note: Task drafted.
  - action: started
    by: backend-agent-01
    at: 2026-01-01T01:00:00Z
    note: start-implementation completed successfully.
